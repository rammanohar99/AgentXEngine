# ─────────────────────────────────────────────────────────────────────────────
# AI Engineering OS — Frontend Environment Variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# All variables must be prefixed with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────────────────────
# Local development:
#   Leave empty — Vite's dev server proxies /api → http://localhost:8000
#   (proxy is configured in vite.config.ts)
#
# Production / staging:
#   Set to your deployed backend URL, e.g. https://api.yourdomain.com
VITE_API_URL=
