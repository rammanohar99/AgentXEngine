# ─────────────────────────────────────────────────────────────────────────────
# AI Engineering OS — Backend Environment Variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Required fields are marked  ← REQUIRED
# Everything else has a working default for local development.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="AI Engineering OS"
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# Default matches the docker-compose postgres service.
# Change host/port if running Postgres outside Docker.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aiengos

# ── Redis ─────────────────────────────────────────────────────────────────────
# Default matches the docker-compose redis service.
REDIS_URL=redis://localhost:6379/0

# ── Google Cloud / Vertex AI  ← REQUIRED for AI features ─────────────────────
# Option A — Application Default Credentials (recommended for local dev):
#   Run: gcloud auth application-default login
#   Then set your project ID below. Leave GEMINI_API_KEY empty.
#   Also set GCLOUD_CONFIG_DIR to your local gcloud config folder:
#     Windows : C:/Users/<you>/AppData/Roaming/gcloud
#     macOS   : /Users/<you>/.config/gcloud
#     Linux   : /home/<you>/.config/gcloud
#
# Option B — Gemini Developer API key (simpler, no GCP project needed):
#   Get a key at https://aistudio.google.com/app/apikey
#   Set GEMINI_API_KEY and leave GOOGLE_CLOUD_PROJECT empty.

GOOGLE_CLOUD_PROJECT=your-gcp-project-id   # ← REQUIRED (Option A)
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash
VERTEX_AI_FALLBACK_MODEL=gemini-2.0-flash-lite

GEMINI_API_KEY=                            # ← REQUIRED (Option B, overrides ADC)

# Path to your local gcloud config directory (used by docker-compose volume mount)
# Only needed for Option A (ADC). Leave empty if using GEMINI_API_KEY.
GCLOUD_CONFIG_DIR=

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-secret   # ← REQUIRED in production

# ── Langfuse — Observability (optional) ──────────────────────────────────────
# Sign up at https://cloud.langfuse.com — leave blank to disable tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# Personal access token — increases GitHub API rate limit from 60 → 5000 req/hr.
# Only needed if you use the GitHub tool in the agent.
# Generate at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# ── Reliability tuning (optional — defaults are production-safe) ──────────────
LLM_TIMEOUT_SECONDS=60.0
TOOL_TIMEOUT_SECONDS=30.0
AGENT_RUN_TIMEOUT_SECONDS=300.0
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=60.0

# ── Context engineering (optional) ────────────────────────────────────────────
MAX_CONTEXT_TOKENS=100000
MAX_TOOL_OUTPUT_CHARS=8000
MAX_HISTORY_MESSAGES=50
